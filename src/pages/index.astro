<style>
  /* ============================================
     FONT FACE — cargamos Chicago FLF desde local
     ============================================ */
  @font-face {
    font-family: 'Chicago FLF';
    src: url('/fonts/ChicagoFLF.ttf') format('truetype');
    font-weight: normal;
    font-style: normal;
    font-display: swap;
  }

  /* ============================================
     RESET — desactivar márgenes y paddings default
     ============================================ */
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html, body {
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  /* ============================================
     ESCRITORIO — la capa atmosférica completa
     ============================================ */
  .desktop {
    width: 100vw;
    height: 100vh;
    position: relative;

    /* Color base: Noche Profunda */
    background-color: #0F2535;

    /* Resplandores radiales sutiles que sugieren neones lejanos */
    background-image:
      radial-gradient(ellipse at 20% 30%, rgba(245, 184, 0, 0.04) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 70%, rgba(255, 107, 0, 0.06) 0%, transparent 50%),
      radial-gradient(ellipse at 50% 100%, rgba(224, 32, 32, 0.05) 0%, transparent 60%);

    /* Permite contenido encima sin que se vea afectado por los efectos */
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 24px;
    overflow: hidden;
  }

  /* ============================================
     VIÑETA RADIAL — oscurece los bordes
     Crea la sensación de "monitor en una pieza oscura"
     ============================================ */
  .desktop::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse at center,
      transparent 30%,
      rgba(0, 0, 0, 0.5) 100%
    );
    pointer-events: none;
    z-index: 2;
  }

  /* ============================================
     SCANLINES CRT — líneas horizontales sutiles
     ============================================ */
  .desktop::after {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      rgba(0, 0, 0, 0.18) 0,
      rgba(0, 0, 0, 0.18) 1px,
      transparent 1px,
      transparent 3px
    );
    pointer-events: none;
    z-index: 3;
  }

  /* ============================================
     TEXTOS DE PRUEBA — para verificar que las fonts cargaron
     Más adelante esto lo borramos
     ============================================ */
  .test-chicago,
  .test-vt323,
  .test-pressstart {
    position: relative;
    z-index: 10; /* arriba de la viñeta y las scanlines */
    color: #ffffff;
    text-align: center;
  }

  .test-chicago {
    font-family: 'Chicago FLF', 'Geneva', 'Tahoma', sans-serif;
    font-size: 48px;
    letter-spacing: 4px;
    color: #F5B800;
    text-shadow:
      0 0 8px rgba(245, 184, 0, 0.6),
      0 0 16px rgba(245, 184, 0, 0.3);
