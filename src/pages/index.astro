---
import Menubar from '../components/Menubar.astro';
import Ticker from '../components/Ticker.astro';
import Desktop from '../components/Desktop.astro';
import Window from '../components/Window.astro';
import Dock from '../components/Dock.astro';
import LoadingScreen from '../components/LoadingScreen.astro';
import TVPlayer from '../components/TVPlayer.astro';
import RadioPlayer from '../components/RadioPlayer.astro';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>LINEA 152 — Booting...</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=VT323&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
   <LoadingScreen />

    <Menubar />

    <main class="desktop">
      <Desktop />

      <!-- Las ventanas: una por cada ícono -->
      <Window id="tv" title="Linea 152 — TV" width={540} height={600} initialX={120} initialY={40}>
  <TVPlayer />
</Window>

      <Window id="radio" title="Radio Porteña — LÍNEA 152" width={500} height={430} initialX={220} initialY={50}>
        <RadioPlayer />
      </Window>

      <Window id="mapa" title="Mapa BSAS — bsas.bmp" width={420} height={320} initialX={260} initialY={90}>
        <p><strong>Mapa de Buenos Aires — placeholder</strong></p>
        <p>SVG interactivo de CABA. Click en barrio abre archivo del barrio.</p>
        <p style="margin-top:8px;opacity:0.6;">[Construcción en Fase 3]</p>
      </Window>

      <Window id="clima" title="Clima Porteño" width={220} height={200} initialX={300} initialY={130}>
        <p><strong>Clima — placeholder</strong></p>
        <p>Datos en vivo de Buenos Aires vía Open-Meteo.</p>
        <p style="margin-top:8px;opacity:0.6;">[Construcción en Fase 4]</p>
      </Window>

      <Window id="eventos" title="Cartelera — eventos.txt" width={340} height={300} initialX={340} initialY={70}>
        <p><strong>Eventos — placeholder</strong></p>
        <p>Cartelera cultural porteña, estilo flyer board.</p>
        <p style="margin-top:8px;opacity:0.6;">[Construcción en Fase 5]</p>
      </Window>

      <Window id="newsletter" title="Newsletter — Transmisión Semanal" width={340} height={280} initialX={380} initialY={110}>
        <p><strong>Newsletter — placeholder</strong></p>
        <p>Suscripción y últimas transmisiones.</p>
        <p style="margin-top:8px;opacity:0.6;">[Construcción en Fase 5]</p>
      </Window>

      <Window id="club" title="Miembros del Club · 152" width={300} height={300} initialX={420} initialY={80}>
        <p><strong>Club — placeholder</strong></p>
        <p>Lista de miembros con scroll automático.</p>
        <p style="margin-top:8px;opacity:0.6;">[Construcción en Fase 5]</p>
      </Window>

      <Window id="merch" title="Tienda — merch.exe" width={420} height={320} initialX={300} initialY={140}>
        <p><strong>Merch — placeholder</strong></p>
        <p>Remeras, stickers, posters. Atmósfera: Amanecer Porteño.</p>
        <p style="margin-top:8px;opacity:0.6;">[Construcción en Fase 6]</p>
      </Window>

      <Window id="about" title="About this computer..." width={340} height={260} initialX={360} initialY={100}>
        <p><strong>Acerca de Línea 152</strong></p>
        <p>Archivo digital emocional de Buenos Aires.</p>
        <p style="margin-top:8px;opacity:0.6;">[Manifiesto completo en Fase 6]</p>
      </Window>

      <Dock />
    </main>

    <Ticker />

    <!-- Script global del window manager -->
    <script src="/src/scripts/windowManager.js"></script>
  </body>
</html>

<style is:global>
  /* Ventanas con contenido especial: sin padding en el body */
  .window:has(.tv-player) .window-body,
  .window:has(.radio-player) .window-body {
    padding: 0;
    overflow: hidden;
  }

  @font-face {
    font-family: 'Chicago FLF';
    src: url('/fonts/ChicagoFLF.ttf') format('truetype');
    font-weight: normal;
    font-style: normal;
    font-display: swap;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html, body {
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .desktop {
    width: 100vw;
    height: 100vh;
    position: relative;
    background-color: #0F2535;
    background-image:
      radial-gradient(ellipse at 20% 30%, rgba(245, 184, 0, 0.04) 0%, transparent 50%),
      radial-gradient(ellipse at 80% 70%, rgba(255, 107, 0, 0.06) 0%, transparent 50%),
      radial-gradient(ellipse at 50% 100%, rgba(224, 32, 32, 0.05) 0%, transparent 60%);
    overflow: hidden;
    padding-top: 24px;
    padding-bottom: 32px;
  }

  .desktop::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center, transparent 30%, rgba(0, 0, 0, 0.5) 100%);
    pointer-events: none;
    z-index: 2;
  }

  .desktop::after {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      rgba(0, 0, 0, 0.18) 0,
      rgba(0, 0, 0, 0.18) 1px,
      transparent 1px,
      transparent 3px
    );
    pointer-events: none;
    z-index: 3;
  }
</style>