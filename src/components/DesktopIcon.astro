---
interface Props {
  name: string;
  imageSrc: string;
  targetId: string;
}

const { name, imageSrc, targetId } = Astro.props;
---

<button class="desktop-icon" data-target={targetId}>
  <div class="icon-image-wrapper">
    <img src={imageSrc} alt={name} class="icon-image" />
  </div>
  <span class="icon-name">{name}</span>
</button>

<style>
  .desktop-icon {
    background: none;
    border: none;
    padding: 8px 6px;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    width: 88px;
    border-radius: 4px;
    transition: transform 0.08s;
  }

  .desktop-icon:hover {
    background: rgba(255, 255, 255, 0.05);
  }

  .desktop-icon:hover .icon-image {
    transform: translateY(-2px);
    filter: drop-shadow(0 0 8px rgba(245, 184, 0, 0.4));
  }

  .desktop-icon:active {
    transform: translateY(1px);
  }

  .icon-image-wrapper {
    width: 64px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .icon-image {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    image-rendering: pixelated;
    image-rendering: -moz-crisp-edges;
    image-rendering: crisp-edges;
    transition: transform 0.15s ease-out, filter 0.15s ease-out;
    /* Sombra dura debajo del ícono para que se despegue del fondo */
    filter: drop-shadow(2px 2px 0 rgba(0, 0, 0, 0.7));
  }

  .icon-name {
    color: #fff;
    font-family: 'Chicago FLF', 'Geneva', 'Tahoma', sans-serif;
    font-size: 12px;
    text-shadow:
      1px 1px 0 #000,
      0 0 6px rgba(0, 0, 0, 0.8);
    letter-spacing: 0.5px;
    text-align: center;
  }
</style>