<script>
  // ========================================
  // TV PLAYER — Lógica de Línea 152
  // ========================================

  // Estado global del player
  const tvState = {
    isOn: false,           // si la TV está prendida
    isPlaying: false,      // si está reproduciendo
    isMuted: false,        // si está muteado
    volume: 70,            // volumen 0-100
    currentChannelIdx: 0,  // índice del canal actual
    currentClipIdx: 0,     // índice del clip actual dentro del canal
    youtubePlayer: null,   // referencia al iframe player de YouTube
    timeUpdateInterval: null, // interval para actualizar el tiempo
    channels: [],          // se carga del JSON embebido
  };

  // === Cargar datos de canales desde el JSON embebido ===
  function loadChannels() {
    const dataEl = document.getElementById('tv-channels-data');
    if (!dataEl) return [];
    try {
      return JSON.parse(dataEl.textContent || '[]');
    } catch (err) {
      console.error('Error parsing channels:', err);
      return [];
    }
  }

  // === Cargar la API de YouTube IFrame ===
  function loadYouTubeAPI() {
    return new Promise((resolve) => {
      // Si ya está cargada
      if (window.YT && window.YT.Player) {
        resolve();
        return;
      }
      // Crear el script tag
      const tag = document.createElement('script');
      tag.src = 'https://www.youtube.com/iframe_api';
      const firstScript = document.getElementsByTagName('script')[0];
      firstScript.parentNode.insertBefore(tag, firstScript);

      // YouTube llamará a esta función global cuando esté lista
      window.onYouTubeIframeAPIReady = () => {
        resolve();
      };
    });
  }

  // === Crear el player de YouTube ===
  function createYouTubePlayer(clip) {
  return new Promise((resolve) => {
    tvState.youtubePlayer = new YT.Player('youtube-player', {
      height: '100%',
      width: '100%',
      videoId: clip.youtubeId,
      playerVars: {
        autoplay: 0,
        controls: 0,
        disablekb: 1,
        fs: 0,
        modestbranding: 1,
        rel: 0,
        showinfo: 0,
        iv_load_policy: 3,
        start: clip.startSeconds,
        end: clip.endSeconds,
        playsinline: 1,
        cc_load_policy: 0,
        color: 'white',
        enablejsapi: 1,
      },
      events: {
        onReady: (event) => {
          event.target.setVolume(tvState.volume);
          // Aplicar el "zoom" al iframe para esconder branding de YouTube
          applyIframeZoom();
          resolve(event.target);
        },
        onStateChange: onPlayerStateChange,
      },
    });
  });
}

// === Esconder branding de YouTube escalando el iframe ===
function applyIframeZoom() {
  const iframe = document.querySelector('#youtube-player');
  if (!iframe) return;
  iframe.style.position = 'absolute';
  iframe.style.width = '180%';
  iframe.style.height = '180%';
  iframe.style.top = '-40%';
  iframe.style.left = '-40%';
  iframe.style.pointerEvents = 'none';
}

  // === Manejar cambios de estado del video (play/pause/ended) ===
  function onPlayerStateChange(event) {
    // YT.PlayerState.ENDED === 0
    // YT.PlayerState.PLAYING === 1
    // YT.PlayerState.PAUSED === 2
    if (event.data === 0) {
      // Video terminó → siguiente clip con transición de static
      nextClip();
    } else if (event.data === 1) {
      tvState.isPlaying = true;
      startTimeUpdate();
    } else if (event.data === 2) {
      tvState.isPlaying = false;
      stopTimeUpdate();
    }
  }

  // === Encender la TV (primera vez) ===
  async function powerOnTV() {
    const offScreen = document.getElementById('tv-off-screen');
    if (!offScreen) return;

    // Cargar API de YouTube si no está
    await loadYouTubeAPI();

    // Crear el player con el primer clip del canal actual
    const currentClip = getCurrentClip();
    if (!currentClip) return;

    await createYouTubePlayer(currentClip);

    // Reproducir
    tvState.youtubePlayer.playVideo();
    tvState.isOn = true;

    // Ocultar la pantalla apagada
    offScreen.classList.add('is-hidden');
  }

  // === Obtener canal y clip actual ===
  function getCurrentChannel() {
    return tvState.channels[tvState.currentChannelIdx];
  }

  function getCurrentClip() {
    const ch = getCurrentChannel();
    return ch ? ch.clips[tvState.currentClipIdx] : null;
  }

  // === Mostrar el static y cargar siguiente clip ===
  function showStaticTransition(callback) {
    const staticOverlay = document.getElementById('tv-static-overlay');
    if (!staticOverlay) {
      if (callback) callback();
      return;
    }

    staticOverlay.classList.add('is-active');

    setTimeout(() => {
      if (callback) callback();
      // Mantener static un poquito más mientras carga el siguiente
      setTimeout(() => {
        staticOverlay.classList.remove('is-active');
      }, 400);
    }, 350);
  }

  // === Cargar un clip específico en el player ===
  function loadClip(clip) {
    if (!tvState.youtubePlayer || !clip) return;

    tvState.youtubePlayer.loadVideoById({
      videoId: clip.youtubeId,
      startSeconds: clip.startSeconds,
      endSeconds: clip.endSeconds,
    });

    updateClipUI(clip);
  }

  // === Actualizar la UI con datos del clip actual ===
  function updateClipUI(clip) {
    const channel = getCurrentChannel();

    const channelLabel = document.getElementById('tv-channel-label');
    const dateLabel = document.getElementById('tv-date-label');
    const filename = document.getElementById('tv-filename');
    const title = document.getElementById('tv-title');
    const artist = document.getElementById('tv-artist');

    if (channelLabel && channel) channelLabel.textContent = `CH ${channel.number}`;
    if (dateLabel) dateLabel.textContent = clip.date;
    if (filename) filename.textContent = clip.filename;
    if (title) title.textContent = clip.title;
    if (artist) artist.textContent = clip.artist;
  }

  // === Ir al siguiente clip ===
  function nextClip() {
    const channel = getCurrentChannel();
    if (!channel) return;

    showStaticTransition(() => {
      tvState.currentClipIdx = (tvState.currentClipIdx + 1) % channel.clips.length;
      loadClip(getCurrentClip());
    });
  }

  // === Ir al clip anterior ===
  function prevClip() {
    const channel = getCurrentChannel();
    if (!channel) return;

    showStaticTransition(() => {
      tvState.currentClipIdx = (tvState.currentClipIdx - 1 + channel.clips.length) % channel.clips.length;
      loadClip(getCurrentClip());
    });
  }

  // === Cambiar de canal ===
  function changeChannel(channelId) {
    const idx = tvState.channels.findIndex(c => c.id === channelId);
    if (idx === -1) return;

    showStaticTransition(() => {
      tvState.currentChannelIdx = idx;
      tvState.currentClipIdx = 0;
      loadClip(getCurrentClip());
    });
  }

  // === Play / Pause ===
  function playVideo() {
    if (tvState.youtubePlayer && tvState.isOn) {
      tvState.youtubePlayer.playVideo();
    }
  }

  function pauseVideo() {
    if (tvState.youtubePlayer && tvState.isOn) {
      tvState.youtubePlayer.pauseVideo();
    }
  }

  // === Actualizar el tiempo mostrado ===
  function startTimeUpdate() {
    stopTimeUpdate();
    tvState.timeUpdateInterval = setInterval(() => {
      if (!tvState.youtubePlayer || !tvState.isOn) return;
      const currentTime = tvState.youtubePlayer.getCurrentTime();
      const clip = getCurrentClip();
      if (!clip) return;
      // Mostrar tiempo relativo al inicio del clip
      const relativeTime = currentTime - clip.startSeconds;
      const mm = String(Math.floor(relativeTime / 60)).padStart(2, '0');
      const ss = String(Math.floor(relativeTime % 60)).padStart(2, '0');
      const timeEl = document.getElementById('tv-current-time');
      if (timeEl) timeEl.textContent = `${mm}:${ss}`;
    }, 500);
  }

  function stopTimeUpdate() {
    if (tvState.timeUpdateInterval) {
      clearInterval(tvState.timeUpdateInterval);
      tvState.timeUpdateInterval = null;
    }
  }

  // === Volumen ===
  function setVolume(value) {
    tvState.volume = value;
    if (tvState.youtubePlayer && tvState.isOn) {
      tvState.youtubePlayer.setVolume(value);
    }
    // Actualizar visualmente el slider (la parte rellena)
    const slider = document.getElementById('tv-volume-slider');
    if (slider) {
      slider.style.setProperty('--fill-percent', `${value}%`);
    }
    // Si el volumen sube por encima de 0, desmutear el icono
    if (value > 0 && tvState.isMuted) {
      tvState.isMuted = false;
      updateVolumeIcon();
    }
  }

  function toggleMute() {
    tvState.isMuted = !tvState.isMuted;
    if (tvState.youtubePlayer && tvState.isOn) {
      if (tvState.isMuted) {
        tvState.youtubePlayer.mute();
      } else {
        tvState.youtubePlayer.unMute();
      }
    }
    updateVolumeIcon();
  }

  function updateVolumeIcon() {
    const icon = document.getElementById('tv-volume-icon');
    if (!icon) return;
    icon.src = tvState.isMuted
      ? '/images/tvplayer/icon-volume-mute.png'
      : '/images/tvplayer/icon-volume.png';
  }

  // === Fullscreen ===
  function toggleFullscreen() {
    const tvPlayer = document.getElementById('tv-player');
    if (!tvPlayer) return;

    if (!document.fullscreenElement) {
      tvPlayer.requestFullscreen().catch(err => {
        console.log('No se pudo abrir fullscreen:', err.message);
      });
    } else {
      document.exitFullscreen();
    }
  }

  // === Inicialización ===
  function initTVPlayer() {
    // Cargar canales
    tvState.channels = loadChannels();
    if (tvState.channels.length === 0) {
      console.warn('No hay canales cargados en TVPlayer');
      return;
    }

    // Inicializar UI con primer clip
    const firstClip = getCurrentClip();
    if (firstClip) updateClipUI(firstClip);

    // Inicializar el volumen visual
    setVolume(tvState.volume);

    // === Bindings de botones ===

    // Botón ENCENDER TV
    const powerBtn = document.getElementById('tv-power-button');
    if (powerBtn) {
      powerBtn.addEventListener('click', powerOnTV);
    }

    // Play / Pause
    const playBtn = document.getElementById('tv-play-btn');
    const pauseBtn = document.getElementById('tv-pause-btn');
    if (playBtn) playBtn.addEventListener('click', playVideo);
    if (pauseBtn) pauseBtn.addEventListener('click', pauseVideo);

    // Next / Prev
    const nextBtn = document.getElementById('tv-next-btn');
    const prevBtn = document.getElementById('tv-prev-btn');
    if (nextBtn) nextBtn.addEventListener('click', nextClip);
    if (prevBtn) prevBtn.addEventListener('click', prevClip);

    // Volume slider
    const volumeSlider = document.getElementById('tv-volume-slider');
    if (volumeSlider) {
      volumeSlider.addEventListener('input', (e) => {
        setVolume(parseInt(e.target.value, 10));
      });
    }

    // Volume toggle (mute)
    const volumeToggle = document.getElementById('tv-volume-toggle');
    if (volumeToggle) volumeToggle.addEventListener('click', toggleMute);

    // Channel selector
    const channelSelect = document.getElementById('tv-channel-select');
    if (channelSelect) {
      channelSelect.addEventListener('change', (e) => {
        changeChannel(e.target.value);
      });
    }

    // Fullscreen
    const fullscreenBtn = document.getElementById('tv-fullscreen-btn');
    if (fullscreenBtn) fullscreenBtn.addEventListener('click', toggleFullscreen);
  }

  // Arrancar cuando el DOM esté listo
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initTVPlayer);
  } else {
    initTVPlayer();
  }
</script>