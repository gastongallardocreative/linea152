---
// TVPlayer.astro
// Componente del reproductor de TV — Línea 152
// Por ahora canales hardcodeados, después conectamos Sanity

// Configuración de canales y clips
// Más adelante esto va a venir de Sanity
const channels = [
  {
    id: 'diego',
    number: '01',
    name: 'El Pibe de oro',
    clips: [
      {
        youtubeId: 'HxjuMPMC4gM',
        startSeconds: 10,
        endSeconds: 30,
        filename: 'maradona_jubilados.avi',
        date: '1992',
        title: 'Hay que ser muy cagón para no defender a los jubilados',
        artist: 'Diego',
      },
    ],
  },
];

// Datos del primer canal/clip para renderizar inicial
const initialChannel = channels[0];
const initialClip = initialChannel.clips[0];
---

<div class="tv-player" id="tv-player">
  <!-- Área del video (negro CRT por default) -->
  <div class="tv-screen" id="tv-screen">
    <!-- Logo Telefe arriba a la izquierda -->
    <img
      src="/images/tvplayer/logo-tv.png"
      alt="TV"
      class="tv-logo"
    />

    <!-- Pantalla apagada con botón ENCENDER -->
    <div class="tv-off-screen" id="tv-off-screen">
      <button class="tv-power-button" id="tv-power-button">
        <span class="power-arrow">▶</span> ENCENDER TV
      </button>
    </div>

    <!-- Iframe de YouTube (oculto hasta que se prende) -->
    <div class="tv-video-container" id="tv-video-container">
      <div id="youtube-player"></div>
    </div>

    <!-- Overlay CRT (scanlines, viñeta) sobre el video -->
    <div class="tv-crt-overlay"></div>

    <!-- Overlay de transición (ruido/static entre videos) -->
    <div class="tv-static-overlay" id="tv-static-overlay"></div>

    <!-- Metadata sobre el video (CH 01, fecha) -->
    <div class="tv-video-meta">
      <div class="tv-channel-label" id="tv-channel-label">CH {initialChannel.number}</div>
      <div class="tv-date-label" id="tv-date-label">{initialClip.date}</div>
    </div>

    <!-- Filename + dimensiones video (abajo) -->
    <div class="tv-video-footer">
      <span class="tv-controls-mini">
        <img src="/images/tvplayer/btn-skip-back.png" alt="skip-back" class="mini-icon" />
        <img src="/images/tvplayer/btn-skip-forward.png" alt="skip-forward" class="mini-icon" />
      </span>
      <span class="tv-filename" id="tv-filename">{initialClip.filename}</span>
      <span class="tv-fullscreen-mini">
        <img src="/images/tvplayer/icon-fullscreen.png" alt="fullscreen" class="mini-icon" />
      </span>
    </div>
  </div>

  <!-- Panel blanco de controles -->
  <div class="tv-controls-panel">
    <!-- Sección título + info -->
    <div class="tv-info-row">
      <div class="tv-info-text">
        <div class="tv-title" id="tv-title">{initialClip.title}</div>
        <div class="tv-artist" id="tv-artist">{initialClip.artist}</div>
      </div>
      <div class="tv-info-buttons">
        <button class="tv-icon-button" id="tv-like-btn" title="Me gusta">
          <img src="/images/tvplayer/btn-like.png" alt="like" />
        </button>
        <button class="tv-icon-button" id="tv-share-btn" title="Compartir">
          <img src="/images/tvplayer/btn-share.png" alt="share" />
        </button>
      </div>
    </div>

    <!-- Sección tiempo + controles -->
    <div class="tv-controls-row">
      <div class="tv-time-display">
        <span class="tv-time-arrow">▶</span>
        <span id="tv-current-time">00:00</span>
      </div>

      <div class="tv-playback-controls">
        <button class="tv-control-btn" id="tv-play-btn" title="Play">
          <img src="/images/tvplayer/btn-play.png" alt="play" />
        </button>
        <button class="tv-control-btn" id="tv-pause-btn" title="Pause">
          <img src="/images/tvplayer/btn-pause.png" alt="pause" />
        </button>
        <button class="tv-control-btn" id="tv-prev-btn" title="Anterior">
          <img src="/images/tvplayer/btn-skip-back.png" alt="prev" />
        </button>
        <button class="tv-control-btn" id="tv-next-btn" title="Siguiente">
          <img src="/images/tvplayer/btn-skip-forward.png" alt="next" />
        </button>
      </div>
    </div>
  </div>

  <!-- Statusbar inferior gris -->
  <div class="tv-statusbar">
    <!-- Dropdown selector de canal -->
    <div class="tv-channel-selector">
      <span class="channel-label">Canal:</span>
      <select id="tv-channel-select" class="tv-channel-dropdown">
        {channels.map(channel => (
          <option value={channel.id}>{channel.name}</option>
        ))}
      </select>
      <img
        src="/images/tvplayer/icon-dropdown-arrow.png"
        alt="▾"
        class="dropdown-arrow"
      />
    </div>

    <!-- Control de volumen -->
    <div class="tv-volume-control">
      <button class="tv-volume-toggle" id="tv-volume-toggle">
        <img
          src="/images/tvplayer/icon-volume.png"
          alt="volume"
          id="tv-volume-icon"
        />
      </button>
      <div class="tv-volume-slider-wrapper">
        <input
          type="range"
          min="0"
          max="100"
          value="70"
          class="tv-volume-slider"
          id="tv-volume-slider"
        />
      </div>
    </div>

    <!-- Botón fullscreen -->
    <button class="tv-fullscreen-btn" id="tv-fullscreen-btn" title="Pantalla completa">
      <img src="/images/tvplayer/icon-fullscreen.png" alt="fullscreen" />
    </button>
  </div>
</div>

<!-- Datos de canales para usar desde JS -->
<script type="application/json" id="tv-channels-data" set:html={JSON.stringify(channels)}></script>
<style>
