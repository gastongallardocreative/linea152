---
// Loading screen estilo Poolsuite con identidad Línea 152

// Imágenes disponibles para el loading
// Cada visita elige una al azar para reforzar "archivo encontrado"
const loadingImages = [
  '/images/loading/diego-radio.jpg',
  // Agregar más fotos acá cuando las tengas:
  // '/images/loading/almagro-balcon.jpg',
  // '/images/loading/taxi-noche.jpg',
];

// Jingles disponibles para el loading
// Más adelante agregamos más (Transmundo, VCD, etc.)
const loadingJingles = [
  '/audio/loading/gativideo-chime.mp3',
];
---

<div class="loading-screen" id="loading-screen">
  <div class="loading-card">
    <!-- Imagen evocativa -->
    <div class="loading-image">
      <img
        src={loadingImages[0]}
        alt="Línea 152"
        id="loading-image"
        class="loading-photo"
      />
      <div class="vhs-overlay">
        <span class="vhs-rec">● REC</span>
        <span class="vhs-date">18·OCT·1998</span>
      </div>
    </div>

    <!-- Contenido textual -->
    <div class="loading-content">
      <h1 class="loading-title">LINEA 152</h1>
      <p class="loading-subtitle">Cultural OS · Versión 1.5.2</p>
      <p class="loading-credits">
        Compilado en Buenos Aires, 2026<br />
        Gallardo G., archivos<br />
        de la ciudad, vecinos anónimos<br />
        Copyright 1986—2026 Línea 152 SRL
      </p>

      <div class="loading-status">
        <p class="status-line">
          Solicitando <span id="loading-filename">archivo_porteño.avi</span>...
          <span id="loading-percent">0</span>%
        </p>
        <div class="progress-bar">
          <div class="progress-fill" id="progress-fill"></div>
        </div>
      </div>

      <button class="boot-button" id="boot-button">
        <span class="boot-arrow">▶</span> ENCENDER
      </button>
    </div>
  </div>
</div>

<script define:vars={{ loadingImages, loadingJingles }}>
  const filenames = [
    'archivo_porteño.avi',
    'diego_mendoza_1982.avi',
    'tarde_de_almagro.avi',
    'taxi_152_constitucion.avi',
    'telefe_summer_98.avi',
    'cumbia_conurbano.avi',
    'cronica_emergencia.avi',
  ];

  // Elegir imagen random al cargar
  function pickRandomImage() {
    const imgEl = document.getElementById('loading-image');
    if (!imgEl || loadingImages.length === 0) return;
    const randomImg = loadingImages[Math.floor(Math.random() * loadingImages.length)];
    imgEl.src = randomImg;
  }

  function startBoot() {
    const button = document.getElementById('boot-button');
    const fill = document.getElementById('progress-fill');
    const percentEl = document.getElementById('loading-percent');
    const filenameEl = document.getElementById('loading-filename');
    const screen = document.getElementById('loading-screen');

    if (button) button.style.display = 'none';

    // Filename random
    const randomFile = filenames[Math.floor(Math.random() * filenames.length)];
    if (filenameEl) filenameEl.textContent = randomFile;

    // === REPRODUCIR JINGLE RANDOM ===
    try {
      if (loadingJingles.length > 0) {
        const randomJingle = loadingJingles[Math.floor(Math.random() * loadingJingles.length)];
        const jingle = new Audio(randomJingle);
        jingle.volume = 0.7;
        jingle.play().catch(err => {
          console.log('Jingle no disponible:', err.message);
        });
      }
    } catch (err) {
      console.log('Audio no soportado');
    }

    // Animar barra de progreso
    let progress = 0;
    const interval = setInterval(() => {
      progress += Math.random() * 8 + 2;
      if (progress > 100) progress = 100;

      if (fill) fill.style.width = `${progress}%`;
      if (percentEl) percentEl.textContent = Math.floor(progress).toString();

      if (progress >= 100) {
        clearInterval(interval);
        setTimeout(() => {
          if (screen) {
            screen.style.opacity = '0';
            setTimeout(() => {
              if (screen) screen.style.display = 'none';
            }, 600);
          }
        }, 400);
      }
    }, 180);
  }

  document.addEventListener('DOMContentLoaded', () => {
    pickRandomImage();
    const button = document.getElementById('boot-button');
    if (button) {
      button.addEventListener('click', startBoot);
    }
  });
</script>

<style>
  .loading-screen {
    position: fixed;
    inset: 0;
    background: #0F2535;
    background-image:
      radial-gradient(ellipse at 30% 20%, rgba(245, 184, 0, 0.05) 0%, transparent 50%),
      radial-gradient(ellipse at 70% 80%, rgba(255, 107, 0, 0.07) 0%, transparent 50%);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 9999;
    transition: opacity 0.6s ease-out;
  }

  .loading-screen::after {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      rgba(0, 0, 0, 0.2) 0,
      rgba(0, 0, 0, 0.2) 1px,
      transparent 1px,
      transparent 3px
    );
    pointer-events: none;
    z-index: 2;
  }

  .loading-screen::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center, transparent 30%, rgba(0, 0, 0, 0.6) 100%);
    pointer-events: none;
    z-index: 1;
  }

  .loading-card {
    background: #d4d0c8;
    border: 1.5px solid #000;
    box-shadow:
      inset 1px 1px 0 #fff,
      inset -1px -1px 0 #808080,
      6px 6px 0 rgba(0, 0, 0, 0.5);
    display: flex;
    width: 620px;
    max-width: 90vw;
    z-index: 10;
    position: relative;
  }

  /* === Imagen real === */
  .loading-image {
    width: 200px;
    flex-shrink: 0;
    background: #1a1d14;
    border-right: 1.5px solid #000;
    position: relative;
    overflow: hidden;
  }

  .loading-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: saturate(0.85) contrast(1.05);
  }

  /* Tinte VHS sobre la foto */
  .loading-image::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 50% 50%, transparent 40%, rgba(0, 0, 0, 0.4) 100%),
      repeating-linear-gradient(
        0deg,
        rgba(80, 250, 123, 0.04) 0,
        rgba(80, 250, 123, 0.04) 1px,
        transparent 1px,
        transparent 2px
      );
    pointer-events: none;
  }

  .vhs-overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 2;
  }

  .vhs-rec {
    position: absolute;
    top: 10px;
    right: 10px;
    color: #E02020;
    font-family: 'Press Start 2P', monospace;
    font-size: 9px;
    animation: blink 1.2s infinite;
    text-shadow: 1px 1px 0 rgba(0, 0, 0, 0.8);
  }

  @keyframes blink {
    0%, 60% { opacity: 1; }
    61%, 100% { opacity: 0; }
  }

  .vhs-date {
    position: absolute;
    bottom: 12px;
    left: 12px;
    color: #fff;
    font-family: 'VT323', monospace;
    font-size: 14px;
    opacity: 0.85;
    text-shadow: 1px 1px 0 rgba(0, 0, 0, 0.8);
  }

  /* === Contenido textual === */
  .loading-content {
    flex: 1;
    padding: 16px 20px;
    color: #000;
  }

  .loading-title {
    font-family: 'Chicago FLF', 'Geneva', 'Tahoma', sans-serif;
    font-size: 32px;
    letter-spacing: 2px;
    margin-bottom: 4px;
    color: #000;
  }

  .loading-subtitle {
    font-family: 'Chicago FLF', 'Geneva', 'Tahoma', sans-serif;
    font-size: 11px;
    margin-bottom: 12px;
    color: #000;
  }

  .loading-credits {
    font-family: 'VT323', monospace;
    font-size: 13px;
    line-height: 1.4;
    color: #444;
    margin-bottom: 16px;
    font-style: italic;
  }

  .loading-status {
    margin-bottom: 16px;
  }

  .status-line {
    font-family: 'VT323', monospace;
    font-size: 14px;
    margin-bottom: 6px;
    color: #000;
  }

  .progress-bar {
    width: 100%;
    height: 12px;
    background: #fff;
    border: 1px solid #000;
    box-shadow: inset 1px 1px 0 #808080;
    overflow: hidden;
  }

  .progress-fill {
    width: 0%;
    height: 100%;
    background: repeating-linear-gradient(
      90deg,
      #000080 0,
      #000080 6px,
      #0000a0 6px,
      #0000a0 8px
    );
    transition: width 0.2s ease-out;
  }

  .boot-button {
    background: #F5B800;
    border: 1.5px solid #000;
    box-shadow:
      inset 1px 1px 0 rgba(255, 255, 255, 0.4),
      inset -1px -1px 0 rgba(0, 0, 0, 0.3),
      3px 3px 0 rgba(0, 0, 0, 0.6);
    padding: 10px 18px;
    cursor: pointer;
    font-family: 'Press Start 2P', monospace;
    font-size: 12px;
    color: #000;
    letter-spacing: 1px;
    width: 100%;
    transition: transform 0.05s;
  }

  .boot-button:hover {
    background: #ffcc00;
  }

  .boot-button:active {
    transform: translate(2px, 2px);
    box-shadow:
      inset 1px 1px 0 rgba(0, 0, 0, 0.3),
      inset -1px -1px 0 rgba(255, 255, 255, 0.4),
      1px 1px 0 rgba(0, 0, 0, 0.6);
  }

  .boot-arrow {
    margin-right: 6px;
  }
</style>