---
import DesktopIcon from './DesktopIcon.astro';

const icons = [
  { name: 'TV',      imageSrc: '/images/icons/tv.png',      targetId: 'tv' },
  { name: 'RADIO',   imageSrc: '/images/icons/radio.png',   targetId: 'radio' },
  { name: 'MAPA',    imageSrc: '/images/icons/mapa.png',    targetId: 'mapa' },
  { name: 'CLIMA',   imageSrc: '/images/icons/clima.png',   targetId: 'clima' },
  { name: 'EVENTOS', imageSrc: '/images/icons/eventos.png', targetId: 'eventos' },
  { name: 'NEWS',    imageSrc: '/images/icons/news.png',    targetId: 'newsletter' },
  { name: 'CLUB',    imageSrc: '/images/icons/club.png',    targetId: 'club' },
  { name: 'MERCH',   imageSrc: '/images/icons/merch.png',   targetId: 'merch' },
  { name: 'ACERCA',  imageSrc: '/images/icons/about.png',   targetId: 'about' },
];
---

<div class="desktop-icons">
  {icons.map(icon => (
    <DesktopIcon
      name={icon.name}
      imageSrc={icon.imageSrc}
      targetId={icon.targetId}
    />
  ))}
</div>

<style>
  .desktop-icons {
  position: absolute;
  top: 40px;
  left: 24px;

  display: grid;
  grid-template-columns: repeat(2, 1fr);

  gap: 12px 24px;

  z-index: 10;
}
  }
</style>