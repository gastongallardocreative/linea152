---
const categorias = [
  { nombre: 'Entretenimiento',   color: '#E63946' },
  { nombre: 'Estaciones de tren', color: '#00F0FF' },
  { nombre: 'Cafés',             color: '#D4A574' },
  { nombre: 'Restaurantes',      color: '#FF8C1A' },
  { nombre: 'Monumentos',        color: '#A78BFA' },
];
---

<div class="mapa-app">

  <!-- Zona del mapa -->
  <div class="mapa-zona">
    <img
      src="/images/mapa/mapa-buenos-aires.png"
      alt="Mapa isométrico de Buenos Aires"
      class="mapa-img"
      draggable="false"
    />
  </div>

  <!-- Sidebar de filtros -->
  <aside class="mapa-sidebar">
    <div class="mapa-sidebar-title">CATEGORÍAS</div>
    <hr class="mapa-sidebar-sep" />

    <ul class="mapa-categoria-list">
      {categorias.map(cat => (
        <li class="mapa-categoria-item">
          <input
            type="checkbox"
            class="mapa-checkbox"
            disabled
            aria-label={cat.nombre}
          />
          <span class="mapa-color-swatch" style={`background:${cat.color};`}></span>
          <span class="mapa-categoria-label">{cat.nombre}</span>
        </li>
      ))}
    </ul>

    <p class="mapa-sidebar-nota">Próximamente</p>
  </aside>

</div>

<style>
  /* ── Contenedor principal ───────────────────────────────────────── */
  .mapa-app {
    width: 100%;
    height: 100%;
    display: flex;
    overflow: hidden;
  }

  /* ── Zona del mapa ──────────────────────────────────────────────── */
  .mapa-zona {
    flex: 1;
    min-width: 0;
    overflow: auto;
    background: #0a0e1a;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    box-sizing: border-box;
  }

  .mapa-img {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    display: block;
    image-rendering: auto;
  }

  /* ── Sidebar ────────────────────────────────────────────────────── */
  .mapa-sidebar {
    width: 240px;
    min-width: 220px;
    max-width: 280px;
    flex-shrink: 0;
    background: #0E1525;
    border-left: 2px solid #00F0FF;
    box-shadow: -4px 0 16px rgba(0, 240, 255, 0.08);
    display: flex;
    flex-direction: column;
    padding: 20px 18px;
    box-sizing: border-box;
    overflow-y: auto;
  }

  .mapa-sidebar-title {
    font-family: 'Press Start 2P', monospace;
    font-size: 9px;
    color: #F0F0F0;
    letter-spacing: 2px;
    margin-bottom: 12px;
    text-shadow: 0 0 8px rgba(0, 240, 255, 0.4);
  }

  .mapa-sidebar-sep {
    border: none;
    border-top: 1px solid rgba(0, 240, 255, 0.2);
    margin: 0 0 20px 0;
  }

  /* ── Lista de categorías ────────────────────────────────────────── */
  .mapa-categoria-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .mapa-categoria-item {
    display: flex;
    align-items: center;
    gap: 10px;
    cursor: not-allowed;
  }

  /* Checkbox custom cuadrado */
  .mapa-checkbox {
    -webkit-appearance: none;
    appearance: none;
    width: 14px;
    height: 14px;
    background: #1a2040;
    border: 1.5px solid #3a4460;
    flex-shrink: 0;
    cursor: not-allowed;
    opacity: 0.45;
    border-radius: 0;
  }

  /* Swatch de color */
  .mapa-color-swatch {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
    display: block;
    border: 1px solid rgba(255, 255, 255, 0.15);
  }

  /* Label */
  .mapa-categoria-label {
    font-family: 'Press Start 2P', monospace;
    font-size: 7px;
    color: #B8B8B8;
    letter-spacing: 0.5px;
    line-height: 1.6;
    opacity: 0.6;
  }

  /* ── Nota inferior ──────────────────────────────────────────────── */
  .mapa-sidebar-nota {
    margin-top: auto;
    padding-top: 20px;
    font-family: 'VT323', monospace;
    font-size: 13px;
    color: #3a4460;
    letter-spacing: 2px;
    text-align: center;
  }
</style>
